# Frontend API endpoint
NEXT_PUBLIC_API_URL=http://localhost:3001

# Backend (set on Railway/Render)
# DB_HOST=postgres.railway.internal
# DB_PORT=5432
# DB_NAME=nivaas
# DB_USER=postgres
# DB_PASSWORD=your_password

# Admin API key — change this to a long random string in production
ADMIN_API_KEY=change-me-in-production

# SMTP (optional — visit confirmation emails only sent when SMTP_HOST is set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Nivaas" <noreply@yourdomain.com>
